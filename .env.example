# ============================================================
# JARVIS server configuration
# Copy to .env and edit. This file is the ONLY thing that
# changes between a laptop deployment and a cloud deployment.
# ============================================================

# ---- Node identity ----
NODE_NAME=cloud-1

# ---- API security (stopgap until Phase 3 JWT auth) ----
# Every request must send this in the X-API-Key header.
API_KEY=change-me-to-something-long-and-random

# ---- Brain: OpenRouter ----
OPENROUTER_API_KEY=sk-or-your-key-here

# Tiered model router (feedback item #7, built in):
#   fast  = cheap/free, used for short conversational turns
#   smart = used when the router detects code/planning/long input
# Set MODEL_SMART to a paid slug (e.g. anthropic/claude-haiku-4.5)
# to enable escalation; leave it equal to MODEL_FAST to stay at $0.
MODEL_FAST=openrouter/free
MODEL_SMART=openrouter/free

# ---- Brain: local fallback (Ollama) ----
# If set, the router falls through to Ollama when OpenRouter fails.
# From inside Docker on the same machine, use host.docker.internal:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen2.5

# ---- Generation ----
MAX_TOKENS=1024
MAX_HISTORY_MESSAGES=30

# ---- Persona ----
ASSISTANT_NAME=Jarvis
USER_TITLE=sir

# ---- Data layer (hostnames = container names; change only if
#      you point at managed services later) ----
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@postgres:5432/jarvis
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=jarvis

# ---- Memory (Phase 2) ----
# Embeddings run locally (free, offline). The distiller periodically reads
# recent conversations and quietly learns durable facts about you; set
# DISTILL_ENABLED=false to turn that off.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MEMORY_TOP_K=5
MEMORY_MIN_SIMILARITY=0.45
DISTILL_ENABLED=true
DISTILL_INTERVAL_HOURS=6

# ---- Auth (Phase 3) ----
# Optional dedicated signing secret for login badges (JWTs).
# If left empty, API_KEY is used as the secret — fine for one user.
JWT_SECRET=
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30

# ---- Network binding ----
# Laptop: leave as 0.0.0.0 (Tailscale needs it).
# Cloud VPS: set to 127.0.0.1 so the API is reachable ONLY via Caddy/HTTPS.
API_BIND=0.0.0.0
<<<<<<< HEAD

# ---- Backups (Phase 6) ----
# Nightly Postgres dumps land in ./backups, kept for RETENTION days.
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=14
